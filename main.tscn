[node name="EffectLabel" type="Label" parent="CanvasLayer/HUD/EffectRow"]
layout_mode = 2
theme_override_colors/font_color = Color(0.75, 0.52, 0.99, 1)
theme_override_font_sizes/font_size = 13
text = ""

[node name="OverlayPanel" type="PanelContainer" parent="CanvasLayer"]
visible = true
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="OverlayVBox" type="VBoxContainer" parent="CanvasLayer/OverlayPanel"]
layout_mode = 2
alignment = 1

[node name="OverlayIcon" type="Label" parent="CanvasLayer/OverlayPanel/OverlayVBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 48
text = "🐍"
horizontal_alignment = 1

[node name="OverlayTitle" type="Label" parent="CanvasLayer/OverlayPanel/OverlayVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 0.94, 1, 1)
theme_override_font_sizes/font_size = 24
text = "准备开始"
horizontal_alignment = 1

[node name="OverlayMsg" type="Label" parent="CanvasLayer/OverlayPanel/OverlayVBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.53, 0.53, 0.6, 1)
theme_override_font_sizes/font_size = 13
text = "方向键/WASD 移动 · 空格暂停 · ESC重开"
horizontal_alignment = 1
autowrap_mode = 2

[node name="StartButton" type="Button" parent="CanvasLayer/OverlayPanel/OverlayVBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_colors/font_color = Color(0, 0.94, 1, 1)
theme_override_font_sizes/font_size = 20
text = "开始游戏"

[node name="HelpButton" type="Button" parent="CanvasLayer/OverlayPanel/OverlayVBox"]
layout_mode = 2
size_flags_horizontal = 4
theme_override_colors/font_color = Color(0.75, 0.75, 0.85, 1)
theme_override_font_sizes/font_size = 16
text = "帮助"

[node name="MoveTimer" type="Timer" parent="."]
wait_time = 0.28
autostart = false

[node name="AITimer" type="Timer" parent="."]
wait_time = 0.35
autostart = false

[node name="MusicPlayer" type="AudioStreamPlayer" parent="."]
volume_db = -12.0

[connection signal="pressed" from="CanvasLayer/OverlayPanel/OverlayVBox/StartButton" to="." method="_on_start_pressed"]
[connection signal="pressed" from="CanvasLayer/OverlayPanel/OverlayVBox/HelpButton" to="." method="_on_help_pressed"]
[connection signal="timeout" from="MoveTimer" to="." method="_on_move_timer_timeout"]
[connection signal="timeout" from="AITimer" to="." method="_on_ai_timer_timeout"]
