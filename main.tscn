[gd_scene load_steps=2 format=3 uid="uid://main"]

[ext_resource type="Script" path="res://main.gd" id="1"]

[node name="Main" type="Node2D"]
script = ExtResource("1")

[node name="Camera2D" type="Camera2D" parent="."]
position = Vector2(300, 350)
zoom = Vector2(1.3, 1.3)
position_smoothing_enabled = true
position_smoothing_speed = 10.0

[node name="CanvasLayer" type="CanvasLayer" parent="."]

[node name="HUD" type="VBoxContainer" parent="CanvasLayer"]
offset_left = 10.0
offset_top = 6.0
offset_right = 590.0
offset_bottom = 100.0

[node name="Title" type="Label" parent="CanvasLayer/HUD"]
layout_mode = 2
theme_override_colors/font_color = Color(0, 0.94, 1, 1)
theme_override_font_sizes/font_size = 22
text = "霓虹蛇  NEON SERPENT"
horizontal_alignment = 1

[node name="StatsRow" type="HBoxContainer" parent="CanvasLayer/HUD"]
layout_mode = 2
alignment = 1

[node name="ScoreLabel" type="Label" parent="CanvasLayer/HUD/StatsRow"]
